# Copy to .env.local and fill in secrets ( .env.local is gitignored )
#
# If Python still sees host "...", PowerShell may have AIVEN_DATABASE_URL set to a placeholder.
# Run: Remove-Item Env:AIVEN_DATABASE_URL -ErrorAction SilentlyContinue
# App and check_code.py load .env.local with override=True so the file wins over the shell.

# Aiven PostgreSQL — Service URI from Aiven console (copy from Connection info)
AIVEN_DATABASE_URL=postgres://avnadmin:YOUR_PASSWORD@YOUR_HOST:PORT/defaultdb?sslmode=require

# Primary app DB (FlightDatabase). If you use Aiven for everything, set to the SAME URI as AIVEN_DATABASE_URL.
# If DATABASE_URL is missing here, the app falls back to .env (e.g. Neon) — API keys still use Aiven, and you can get confusing auth/DB mismatches.
# If the password contains @ # $ % etc., URL-encode it in the URI (e.g. @ -> %40)
DATABASE_URL=postgres://avnadmin:YOUR_PASSWORD@YOUR_HOST:PORT/defaultdb?sslmode=require

# Booking: require X-API-Key / JWT / trusted referer when set
FLIGHTGRAB_ENFORCE_BOOKING_AUTH=1

# Optional: comma-separated static keys (bypasses DB)
# FLIGHTGRAB_BOOKING_API_KEYS=test_key_123

# App
# JWT_SECRET_KEY=
